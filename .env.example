# ─────────────────────────────────────────────────────────────
#  BugFix Agent — Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Claude API (required) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub (required) ─────────────────────────────────────────
GITHUB_TOKEN=ghp_...           # Personal access token (repo + workflow scopes)
GITHUB_REPO=owner/repo         # e.g. mycompany/backend
DEFAULT_BRANCH=main
GITHUB_WEBHOOK_SECRET=         # Optional: secret set in GitHub webhook settings

# ── CI/CD ─────────────────────────────────────────────────────
CI_WORKFLOW_ID=ci.yml          # Filename of your GitHub Actions workflow
CI_TIMEOUT_MS=600000           # How long to wait for CI (ms). Default: 10 min
AUTO_MERGE=true                # Auto-merge PR when CI passes
MERGE_METHOD=squash            # squash | merge | rebase
DEPLOY_ENV=production

# ── Ticket source ─────────────────────────────────────────────
TICKET_PROVIDER=github         # github | jira

# Jira (only if TICKET_PROVIDER=jira)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_TOKEN=                    # API token from id.atlassian.com
JIRA_TRANSITION_DONE_ID=31     # Transition ID for "Done" status

# ── Notifications ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#engineering

# ── Pipeline behavior ─────────────────────────────────────────
TRIGGER_LABEL=ai-fix           # Label that activates the pipeline
MAX_RETRIES=3                  # Max code fix attempts before escalating
COMMIT_TESTS=true              # Commit Claude-generated tests to the branch

# ── Server ────────────────────────────────────────────────────
PORT=3000
