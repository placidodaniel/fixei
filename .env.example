# ─────────────────────────────────────────────────────────────
#  Fixei — Environment Variables
#  Copy this file to .env and fill in your values.
#  Variables marked (required) will cause the server to refuse
#  to start if missing. All others have safe defaults.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider (optional) ──────────────────────────────────
# openrouter (default) — hosted models via https://openrouter.ai
# ollama               — local models, no API key needed
LLM_PROVIDER=openrouter

# Ollama — only needed if LLM_PROVIDER=ollama
# Make sure `ollama serve` is running before starting Fixei.
# Recommended: ollama pull qwen2.5-coder:7b && ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# ── OpenRouter API (required when LLM_PROVIDER=openrouter) ───
# Unified LLM gateway — supports 200+ models with one key.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── LLM Models — primary (optional) ─────────────────────────
# Model used by each agent. Any model listed at openrouter.ai/models works.
# If not set, defaults to anthropic/claude-3.5-sonnet for all agents.
MODEL_ANALYSIS=deepseek/deepseek-chat          # Root cause analysis (heavier reasoning)
MODEL_CODE=qwen/qwen2.5-coder-7b-instruct      # Code fix generation
MODEL_TEST=qwen/qwen2.5-coder-7b-instruct      # Test file generation
MODEL_TICKET=microsoft/phi-3-mini              # Ticket parsing (lightweight)
MODEL_DOCUMENTATION=deepseek/deepseek-chat     # Codebase docs (defaults to MODEL_ANALYSIS if unset)

# ── Target repository tech stack (optional) ──────────────────
# Used to fetch up-to-date framework best practices via Context7
# and inject them into the CodeAgent prompt for better code quality.
# Examples: TypeScript, NestJS, Vue, React, Laravel, Django, FastAPI
STACK_BACKEND=TypeScript
STACK_FRONTEND=Vue

# ── Context7 — framework best practices injection (optional) ─
# Context7 fetches live docs for your frameworks and injects them
# into code generation prompts so the LLM uses current patterns.
CONTEXT7_ENABLED=true          # Set to false to disable
CONTEXT7_TOKENS=2500           # Max tokens fetched per library

# ── GitHub (required) ────────────────────────────────────────
# Personal access token needs: repo + workflow scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo         # The repository Fixei will fix bugs in
DEFAULT_BRANCH=main            # Branch the agent reads code from
GITHUB_WEBHOOK_SECRET=         # HMAC secret — strongly recommended in production

# ── CI/CD ────────────────────────────────────────────────────
CI_WORKFLOW_ID=ci.yml          # Filename of your GitHub Actions CI workflow
CI_TIMEOUT_MS=600000           # Max time waiting for CI to finish (ms, default: 10 min)
AUTO_MERGE=true                # Auto-merge the PR when CI passes
MERGE_METHOD=squash            # squash | merge | rebase
DEPLOY_ENV=production          # Environment label shown in Slack notifications

# ── Ticket source (optional) ─────────────────────────────────
TICKET_PROVIDER=github         # github | jira

# Jira — only needed if TICKET_PROVIDER=jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_TOKEN=                    # API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TRANSITION_DONE_ID=31     # Transition ID for the "Done" status (check your workflow)

# ── Slack notifications (optional) ───────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#engineering     # Informational — actual channel is set in the webhook itself

# ── Pipeline behavior (optional) ─────────────────────────────
TRIGGER_LABEL=ai-fix           # GitHub Issue label that activates the pipeline
MAX_RETRIES=3                  # Max fix attempts before escalating to a human
COMMIT_TESTS=true              # Commit LLM-generated tests to the fix branch

# ── Server (optional) ────────────────────────────────────────
PORT=3000
